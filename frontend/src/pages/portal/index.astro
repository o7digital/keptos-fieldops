---
import AppLayout from '@/layouts/AppLayout.astro';
import { PortalThemePreview } from '@/components/react/PortalThemePreview';
import { adminTenants, portalThemes } from '@/data/mock';
---

<AppLayout
  title="White-label Portal"
  description="Client-facing tenant preview showing how Keptos can package the platform as a premium branded portal for its own customers."
  activeNav="portal"
  eyebrow="White-label business layer"
>
  <a slot="page-actions" href="/clients" class="action-button action-button-secondary">Client 360</a>
  <a slot="page-actions" href="/admin" class="action-button action-button-primary">Manage branding</a>

  <section class="hero-grid">
    <article class="hero-panel">
      <p class="hero-eyebrow">Monetizable surface</p>
      <h2 class="hero-title">Keptos can rent the same premium orchestration layer to each customer under their own brand identity.</h2>
      <p class="hero-copy">
        The white-label view proves the product can become both an internal operations hub and a client-facing service platform, without losing coherence or quality.
      </p>
      <div class="hero-metric-grid">
        <div class="hero-mini-metric">
          <span>Brand packs</span>
          <strong>6</strong>
          <span>tenant identity kits already prepared for demos</span>
        </div>
        <div class="hero-mini-metric">
          <span>Pilot tenants</span>
          <strong>3</strong>
          <span>workspaces ready to be positioned commercially</span>
        </div>
      </div>
    </article>

    <article class="list-card">
      <div class="panel-header">
        <div>
          <p class="list-title">Commercial posture</p>
          <h3 class="panel-heading">Each tenant can present the platform as its own premium service layer.</h3>
        </div>
      </div>

      <div class="list-stack">
        {adminTenants.map((tenant) => (
          <div class="list-row">
            <strong>{tenant.name}</strong>
            <p>{tenant.connectors}</p>
            <span>{tenant.branding} · {tenant.status}</span>
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="panel-surface">
    <div class="panel-header">
      <div>
        <p class="panel-title">Tenant preview switcher</p>
        <h3 class="panel-heading">A single premium product, multiple identities.</h3>
        <p class="panel-copy">Logos, color accents, dashboard copy, ticket snapshots, reports, and incident posture can all shift per tenant without degrading the premium feel.</p>
      </div>
    </div>

    <PortalThemePreview client:load themes={portalThemes} />
  </section>

  <section class="two-column-grid">
    <article class="feature-card">
      <div class="panel-header">
        <div>
          <p class="panel-title">What the client sees</p>
          <h3 class="panel-heading">A calm, executive-friendly portal instead of raw helpdesk noise.</h3>
        </div>
      </div>

      <div class="list-stack">
        <div class="list-row">
          <strong>Dashboard and service health</strong>
          <p>Clients can consume network score, incidents, interventions, and SLA summaries from one controlled surface.</p>
        </div>
        <div class="list-row">
          <strong>Tickets and reports</strong>
          <p>The same premium UI can expose normalized tickets and engineer reports without exposing internal tooling complexity.</p>
        </div>
        <div class="list-row">
          <strong>Intervention history</strong>
          <p>Every on-site mission becomes part of a visible service narrative that reinforces perceived value.</p>
        </div>
      </div>
    </article>

    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Why this sells</p>
          <h3 class="panel-heading">Keptos can position the product as a branded digital service, not just managed support.</h3>
          <p class="panel-copy">That changes the commercial story: the platform becomes part of the offering, strengthens stickiness, and differentiates Keptos from traditional MSP presentations.</p>
        </div>
      </div>

      <div class="callout">
        <strong>White-label leverage</strong>
        <p>A strong client-facing surface increases perceived maturity, supports premium pricing, and opens room for multi-tenant packaging later.</p>
      </div>
    </article>
  </section>
</AppLayout>
