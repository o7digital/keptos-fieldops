---
import RedirectPage from '@/components/astro/RedirectPage.astro';
import { getLocaleHome, getLocaleStaticPaths, isLocale } from '@/data/i18n';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const { lang } = Astro.params;

if (!isLocale(lang)) {
  throw new Error('Invalid locale');
}
---

<RedirectPage to={getLocaleHome(lang)} />
