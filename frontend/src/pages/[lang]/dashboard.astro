---
import DashboardPage from '@/components/pages/DashboardPage.astro';
import { getLocaleStaticPaths, isLocale } from '@/data/i18n';

export function getStaticPaths() {
  return getLocaleStaticPaths();
}

const { lang } = Astro.params;

if (!isLocale(lang)) {
  throw new Error('Invalid locale');
}
---

<DashboardPage locale={lang} />
