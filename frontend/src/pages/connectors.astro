---
import AppLayout from '@/layouts/AppLayout.astro';
import StatusPill from '@/components/astro/StatusPill.astro';
import { adminLogs, connectorActivity, connectors } from '@/data/mock';
---

<AppLayout
  title="Connectors"
  description="Integration fabric preview for Zendesk, Jira Service Management, ServiceNow, and Freshservice with premium visibility into status, sync posture, and white-label readiness."
  activeNav="connectors"
  eyebrow="Integration fabric"
>
  <a slot="page-actions" href="/tickets" class="action-button action-button-secondary">Open unified queue</a>
  <a slot="page-actions" href="/admin" class="action-button action-button-primary">Control plane</a>

  <section class="hero-grid">
    <article class="hero-panel">
      <p class="hero-eyebrow">Premium sync layer</p>
      <h2 class="hero-title">The connector surface is presented like infrastructure, not like a settings page.</h2>
      <p class="hero-copy">
        This page frames Keptos as a platform that can absorb multiple ITSM ecosystems while preserving a coherent enterprise identity and future white-label potential.
      </p>
      <div class="hero-metric-grid">
        {connectorActivity.map((item) => (
          <div class="hero-mini-metric">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <span>{item.detail}</span>
          </div>
        ))}
      </div>
    </article>

    <article class="hub-visual-card">
      <div class="panel-header">
        <div>
          <p class="panel-title">Connector topology</p>
          <h3 class="panel-heading">Keptos in the middle, tenant-ready connectors at the edge.</h3>
        </div>
      </div>

      <div class="hub-orbit">
        <div class="hub-orbit-stage">
          <div class="hub-ring"></div>
          <div class="hub-core">
            <strong>Sync fabric</strong>
            <span>Mappings, normalization, sync logs, and white-label connector shells.</span>
          </div>
          {connectors.map((connector, index) => (
            <div class:list={[
              'hub-node',
              index === 0 && 'hub-node-zd',
              index === 1 && 'hub-node-jsm',
              index === 2 && 'hub-node-sn',
              index === 3 && 'hub-node-fs',
            ]}>
              <strong>{connector.name}</strong>
              <span>{connector.status}</span>
            </div>
          ))}
        </div>
      </div>
    </article>
  </section>

  <section class="connectors-grid">
    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Connector catalog</p>
          <h3 class="panel-heading">Every integration is shown like a premium capability module.</h3>
        </div>
      </div>

      <div class="connector-card-grid">
        {connectors.map((connector) => (
          <div class="connector-card">
            <StatusPill label={connector.status} tone={connector.stateTone} compact />
            <strong>{connector.name}</strong>
            <p class="panel-copy">{connector.description}</p>
            <div class="estate-meta">
              <span>{connector.lastSync}</span>
              <span>{connector.volume}</span>
              <span>{connector.latency}</span>
            </div>
            <div class="connector-list">
              {connector.coverage.map((item) => <span>{item}</span>)}
            </div>
            <div class="callout">
              <strong>{connector.action}</strong>
              <p>The connector surface is ready to support future activation, mapping, and observability flows.</p>
            </div>
          </div>
        ))}
      </div>
    </article>

    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Latest sync activity</p>
          <h3 class="panel-heading">Operational visibility into the integration fabric.</h3>
        </div>
      </div>

      <div class="sync-log-list">
        {adminLogs.map((entry) => (
          <div class="sync-log-row">
            <strong>{entry.connector} · {entry.status}</strong>
            <p>{entry.message}</p>
            <span>{entry.timestamp}</span>
          </div>
        ))}
      </div>
    </article>
  </section>
</AppLayout>
