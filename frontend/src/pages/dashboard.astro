---
import AppLayout from '@/layouts/AppLayout.astro';
import MetricCard from '@/components/astro/MetricCard.astro';
import StatusPill from '@/components/astro/StatusPill.astro';
import {
  clientPortfolio,
  estateHealth,
  executiveActivity,
  executiveMetrics,
  incidentPulse,
} from '@/data/mock';

const networkScore = 94.2;
---

<AppLayout
  title="Executive Dashboard"
  description="Premium command center for incident pressure, field execution, and client-facing service quality across the entire Keptos managed estate."
  activeNav="dashboard"
  eyebrow="Executive command"
>
  <a slot="page-actions" href="/operations" class="action-button action-button-primary">Open field ops</a>
  <a slot="page-actions" href="/tickets" class="action-button action-button-secondary">Unified queue</a>

  <section class="hero-grid">
    <article class="hero-panel">
      <p class="hero-eyebrow">Orchestration above the helpdesk layer</p>
      <h2 class="hero-title">A serious control cockpit for enterprise infogérance, not a repainted ticketing tool.</h2>
      <p class="hero-copy">
        Keptos Operations Hub consolidates dispatch, network oversight, and multi-platform ticket intake into one premium operational surface designed to feel strategic from the first screen.
      </p>
      <div class="hero-action-row">
        <span class="chrome-chip">34 interventions live today</span>
        <span class="chrome-chip chrome-chip-muted">4 ticket sources normalized</span>
        <span class="chrome-chip chrome-chip-muted">11 engineers currently on site</span>
      </div>
      <div class="hero-metric-grid">
        <div class="hero-mini-metric">
          <span>SLA posture</span>
          <strong>7</strong>
          <span>breaches or near-breaches under active review</span>
        </div>
        <div class="hero-mini-metric">
          <span>Normalized signals</span>
          <strong>38.4k</strong>
          <span>events and records synchronized in the last 24 hours</span>
        </div>
      </div>
    </article>

    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Network command score</p>
          <h3 class="panel-heading">Estate health remains premium-grade despite live carrier pressure.</h3>
        </div>
        <div class="score-ring" style={`--score:${networkScore}`}>
          <strong>{networkScore}</strong>
          <span>health score</span>
        </div>
      </div>

      <div class="telemetry-grid">
        <div>
          <span>Critical sites</span>
          <strong>2</strong>
        </div>
        <div>
          <span>Average response</span>
          <strong>13m</strong>
        </div>
        <div>
          <span>Check-ins validated</span>
          <strong>11 / 11</strong>
        </div>
        <div>
          <span>WAN escalations</span>
          <strong>4</strong>
        </div>
      </div>

      <div class="line-bars">
        {incidentPulse.map((item) => (
          <div class="line-bar-row">
            <span>{item.source}</span>
            <div class="line-bar-track">
              <strong style={`width:${Math.min(100, item.opened * 1.45)}%`}></strong>
            </div>
            <span>{item.opened}</span>
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="metric-grid">
    {executiveMetrics.map((metric) => <MetricCard {...metric} />)}
  </section>

  <section class="dashboard-grid">
    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Recent activity</p>
          <h3 class="panel-heading">The operational timeline reads like a premium command log.</h3>
          <p class="panel-copy">Every escalation, connector sync, and field update is surfaced with enough context to brief management without opening another tool.</p>
        </div>
      </div>

      <div class="activity-feed">
        {executiveActivity.map((entry) => (
          <div class="activity-row">
            <StatusPill label={entry.tone} tone={entry.tone} compact />
            <strong>{entry.title}</strong>
            <p>{entry.detail}</p>
            <span>{entry.timestamp}</span>
          </div>
        ))}
      </div>
    </article>

    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Source pulse</p>
          <h3 class="panel-heading">Multi-ITSM intake remains readable and executive-friendly.</h3>
        </div>
      </div>

      <div class="estate-grid">
        {incidentPulse.map((item) => (
          <div class="estate-card">
            <StatusPill label={item.source} tone={item.tone} compact />
            <strong>{item.opened} open incidents</strong>
            <p class="panel-copy">{item.critical} critical items currently demanding orchestration attention.</p>
            <div class="estate-meta">
              <span>Median response {item.medianResponse}</span>
            </div>
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="two-column-grid">
    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Sites under surveillance</p>
          <h3 class="panel-heading">Every monitored site is framed as an operational asset, not just a ticket origin.</h3>
        </div>
      </div>

      <div class="estate-grid">
        {estateHealth.map((site) => (
          <div class="estate-card">
            <StatusPill label={site.health} tone={site.tone} compact />
            <strong>{site.site}</strong>
            <p class="panel-copy">{site.client}</p>
            <div class="estate-meta">
              <span>Latency {site.latency}</span>
              <span>Loss {site.packetLoss}</span>
              <span>Utilization {site.utilization}</span>
            </div>
          </div>
        ))}
      </div>
    </article>

    <article class="list-card">
      <div class="panel-header">
        <div>
          <p class="list-title">Client momentum</p>
          <h3 class="panel-heading">Accounts with the highest operational intensity today.</h3>
        </div>
      </div>

      <div class="list-stack">
        {clientPortfolio.map((client) => (
          <div class="list-row">
            <StatusPill label={client.health} tone={client.tone} compact />
            <strong>{client.name}</strong>
            <p>{client.mrr} · {client.sites}</p>
            <span>Service quality index {client.health}</span>
          </div>
        ))}
      </div>
    </article>
  </section>
</AppLayout>
