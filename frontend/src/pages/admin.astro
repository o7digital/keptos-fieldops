---
import AppLayout from '@/layouts/AppLayout.astro';
import MetricCard from '@/components/astro/MetricCard.astro';
import StatusPill from '@/components/astro/StatusPill.astro';
import {
  adminEngineers,
  adminLogs,
  adminMetrics,
  adminSites,
  adminTenants,
  connectors,
} from '@/data/mock';
---

<AppLayout
  title="Admin Control Plane"
  description="Internal administration surface for tenants, engineers, managed sites, connector governance, sync visibility, and white-label configuration."
  activeNav="admin"
  eyebrow="Internal control plane"
>
  <a slot="page-actions" href="/portal" class="action-button action-button-secondary">Tenant preview</a>
  <a slot="page-actions" href="/connectors" class="action-button action-button-primary">Connector catalog</a>

  <section class="hero-grid">
    <article class="hero-panel">
      <p class="hero-eyebrow">Operate the platform</p>
      <h2 class="hero-title">An internal admin surface that feels like product infrastructure, not back-office clutter.</h2>
      <p class="hero-copy">
        Tenant setup, sync supervision, branding, and operational staffing are represented as clean control layers inside the same premium visual system.
      </p>
    </article>

    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Connector posture</p>
          <h3 class="panel-heading">At-a-glance governance for the integration estate.</h3>
        </div>
      </div>

      <div class="list-stack">
        {connectors.map((connector) => (
          <div class="list-row">
            <StatusPill label={connector.status} tone={connector.stateTone} compact />
            <strong>{connector.name}</strong>
            <p>{connector.description}</p>
            <span>{connector.lastSync}</span>
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="metric-grid">
    {adminMetrics.map((metric) => <MetricCard {...metric} />)}
  </section>

  <section class="admin-grid">
    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Managed tenants</p>
          <h3 class="panel-heading">White-label configuration posture.</h3>
        </div>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>Tenant</th>
            <th>Branding</th>
            <th>Connectors</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {adminTenants.map((tenant) => (
            <tr>
              <td>{tenant.name}</td>
              <td>{tenant.branding}</td>
              <td>{tenant.connectors}</td>
              <td>{tenant.status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Synchronization logs</p>
          <h3 class="panel-heading">Mock observability for the integration fabric.</h3>
        </div>
      </div>

      <div class="sync-log-list">
        {adminLogs.map((entry) => (
          <div class="sync-log-row">
            <strong>{entry.connector} · {entry.status}</strong>
            <p>{entry.message}</p>
            <span>{entry.timestamp}</span>
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="admin-grid">
    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Engineer roster</p>
          <h3 class="panel-heading">Utilization and specialty coverage.</h3>
        </div>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>Engineer</th>
            <th>Region</th>
            <th>Skill</th>
            <th>Load</th>
          </tr>
        </thead>
        <tbody>
          {adminEngineers.map((engineer) => (
            <tr>
              <td>{engineer.name}</td>
              <td>{engineer.region}</td>
              <td>{engineer.skill}</td>
              <td>{engineer.load}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Managed sites</p>
          <h3 class="panel-heading">Connector and tenant state by site.</h3>
        </div>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>Client</th>
            <th>Site</th>
            <th>Connector</th>
            <th>Brand state</th>
          </tr>
        </thead>
        <tbody>
          {adminSites.map((site) => (
            <tr>
              <td>{site.client}</td>
              <td>{site.site}</td>
              <td>{site.connectorState}</td>
              <td>{site.brandState}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>
</AppLayout>
