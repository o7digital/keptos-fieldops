---
import AppLayout from '@/layouts/AppLayout.astro';
import StatusPill from '@/components/astro/StatusPill.astro';
import { clientPortfolio, featuredClient, missions } from '@/data/mock';

const clientMissions = missions.filter((mission) => mission.client === featuredClient.name);
---

<AppLayout
  title="Client 360"
  description="A premium account intelligence surface combining client profile, sites, users, incidents, interventions, service history, and SLA posture."
  activeNav="clients"
  eyebrow="Account intelligence"
>
  <a slot="page-actions" href="/portal" class="action-button action-button-secondary">White-label preview</a>
  <a slot="page-actions" href="/operations" class="action-button action-button-primary">Open interventions</a>

  <section class="client-hero">
    <article class="client-summary-card">
      <div>
        <p class="hero-eyebrow">Featured account</p>
        <h2 class="client-summary-title">{featuredClient.name}</h2>
        <p class="client-summary-copy">
          {featuredClient.sector} account managed through a premium operations layer, with live field context, normalized tickets, and a service posture intended for executive review.
        </p>
        <div class="hero-action-row">
          <span class="chrome-chip">{featuredClient.contract}</span>
          <span class="chrome-chip chrome-chip-muted">{featuredClient.sla}</span>
        </div>
      </div>

      <div class="score-ring" style="--score:92">
        <strong>92</strong>
        <span>health score</span>
      </div>

      <div class="client-summary-grid">
        <div class="summary-stat">
          <span>MRR</span>
          <strong>{featuredClient.mrr}</strong>
        </div>
        <div class="summary-stat">
          <span>Renewal</span>
          <strong>{featuredClient.renewal}</strong>
        </div>
        <div class="summary-stat">
          <span>Service lead</span>
          <strong>{featuredClient.serviceLead}</strong>
        </div>
        <div class="summary-stat">
          <span>Availability</span>
          <strong>{featuredClient.availability}</strong>
        </div>
      </div>
    </article>
  </section>

  <section class="client-grid">
    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Client sites</p>
          <h3 class="panel-heading">Estate view with health, incident density, and next visit context.</h3>
        </div>
      </div>

      <div class="site-card-grid">
        {featuredClient.sites.map((site) => (
          <div class="site-card">
            <StatusPill label={site.health} tone={site.tone} compact />
            <strong>{site.name}</strong>
            <p class="panel-copy">{site.city}</p>
            <div class="site-meta">
              <span>{site.incidentCount}</span>
              <span>{site.upcomingVisit}</span>
            </div>
          </div>
        ))}
      </div>
    </article>

    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Client incidents</p>
          <h3 class="panel-heading">Active issues contextualized for account management.</h3>
        </div>
      </div>

      <table class="simple-table">
        <thead>
          <tr>
            <th>Incident</th>
            <th>Source</th>
            <th>Priority</th>
            <th>Status</th>
            <th>Updated</th>
          </tr>
        </thead>
        <tbody>
          {featuredClient.incidents.map((incident) => (
            <tr>
              <td>{incident.title}</td>
              <td>{incident.source}</td>
              <td>{incident.priority}</td>
              <td>{incident.status}</td>
              <td>{incident.updatedAt}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>

  <section class="client-grid">
    <article class="list-card">
      <div class="panel-header">
        <div>
          <p class="list-title">Client users</p>
          <h3 class="panel-heading">Business stakeholders and recurrent operational friction points.</h3>
        </div>
      </div>

      <div class="list-stack">
        {featuredClient.users.map((user) => (
          <div class="list-row">
            <strong>{user.name}</strong>
            <p>{user.role} · {user.site}</p>
            <span>{user.recurringIssue}</span>
          </div>
        ))}
      </div>
    </article>

    <article class="list-card">
      <div class="panel-header">
        <div>
          <p class="list-title">Service history</p>
          <h3 class="panel-heading">Client narrative prepared for management reviews.</h3>
        </div>
      </div>

      <div class="list-stack">
        {featuredClient.history.map((entry) => (
          <div class="list-row">
            <strong>{entry.label}</strong>
            <p>{entry.detail}</p>
            <span>{entry.date}</span>
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="two-column-grid">
    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Linked interventions</p>
          <h3 class="panel-heading">Field activity already visible from the account surface.</h3>
        </div>
      </div>

      <div class="activity-feed">
        {clientMissions.map((mission) => (
          <div class="activity-row">
            <StatusPill
              label={mission.priority}
              tone={mission.priority === 'Critical' ? 'danger' : mission.priority === 'High' ? 'warning' : mission.priority === 'Medium' ? 'info' : 'neutral'}
              compact
            />
            <strong>{mission.label} · {mission.site}</strong>
            <p>{mission.summary}</p>
            <span>{mission.engineer} · {mission.status}</span>
          </div>
        ))}
      </div>
    </article>

    <article class="panel-surface">
      <div class="panel-header">
        <div>
          <p class="panel-title">Portfolio context</p>
          <h3 class="panel-heading">Other managed accounts positioned on the same premium scale.</h3>
        </div>
      </div>

      <div class="site-card-grid">
        {clientPortfolio.map((client) => (
          <div class="site-card">
            <StatusPill label={client.health} tone={client.tone} compact />
            <strong>{client.name}</strong>
            <p class="panel-copy">{client.sites}</p>
            <div class="site-meta">
              <span>{client.mrr}</span>
            </div>
          </div>
        ))}
      </div>
    </article>
  </section>
</AppLayout>
