---
import '@/styles/global.css';
import { getCopy, getPagePath, locales, pageSegments, type Locale, type PageKey } from '@/data/i18n';

type Props = {
  title: string;
  description: string;
  activeNav: PageKey;
  locale: Locale;
  eyebrow?: string;
};

const {
  title,
  description,
  activeNav,
  locale,
  eyebrow = 'Keptos Operations Hub',
} = Astro.props as Props;

const copy = getCopy(locale);
const navigation = (Object.keys(pageSegments) as PageKey[]).map((key) => ({
  key,
  href: getPagePath(locale, key),
  label: copy.layout.navigation[key].label,
  hint: copy.layout.navigation[key].hint,
}));
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Keptos Operations Hub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="app-noise"></div>
    <div class="app-gradient app-gradient-left"></div>
    <div class="app-gradient app-gradient-right"></div>

    <div class="shell">
      <aside class="sidebar">
        <div class="sidebar-brand">
          <div class="brand-mark">
            <span>K</span>
          </div>
          <div>
            <p class="sidebar-brand-title">{copy.layout.appName}</p>
            <p class="sidebar-brand-copy">{copy.layout.appTagline}</p>
          </div>
        </div>

        <div class="sidebar-showcase-card">
          <p class="sidebar-showcase-eyebrow">{copy.layout.showcaseEyebrow}</p>
          <p class="sidebar-showcase-title">{copy.layout.showcaseTitle}</p>
          <p class="sidebar-showcase-copy">{copy.layout.showcaseCopy}</p>
        </div>

        <div class="sidebar-block">
          <p class="sidebar-label">{copy.layout.cockpitLabel}</p>
          <nav class="sidebar-nav">
            {navigation.map((item) => (
              <a href={item.href} class:list={['sidebar-link', item.key === activeNav && 'sidebar-link-active']}>
                <span class:list={['sidebar-link-dot', item.key === activeNav && 'sidebar-link-dot-active']}></span>
                <span class="sidebar-link-copy">
                  <span class="sidebar-link-title">{item.label}</span>
                  <span class="sidebar-link-hint">{item.hint}</span>
                </span>
              </a>
            ))}
          </nav>
        </div>

        <div class="sidebar-footer-card">
          <p class="sidebar-label">{copy.layout.workspaceSignalsLabel}</p>
          <div class="sidebar-signal-list">
            {copy.layout.workspaceSignals.map((signal) => (
              <div class="sidebar-signal-row">
                <span>{signal.label}</span>
                <strong>{signal.value}</strong>
              </div>
            ))}
          </div>
        </div>
      </aside>

      <div class="stage">
        <header class="topbar">
          <div class="topbar-copy">
            <div class="topbar-chip-row">
              <span class="chrome-chip">{copy.layout.designPreview}</span>
              <span class="chrome-chip chrome-chip-muted">{copy.layout.mockDataOnly}</span>
            </div>
            <p class="topbar-title">{title}</p>
            <p class="topbar-description">{description}</p>
          </div>
          <div class="topbar-actions">
            <div class="language-switch" aria-label={copy.localeLabel}>
              {locales.map((lang) => (
                <a
                  href={getPagePath(lang, activeNav)}
                  class:list={['language-switch-link', lang === locale && 'language-switch-link-active']}
                >
                  {copy.localeNames[lang]}
                </a>
              ))}
            </div>
            <slot name="page-actions" />
          </div>
        </header>

        <main class="page">
          <div class="page-intro">
            <p class="page-intro-eyebrow">{eyebrow}</p>
            <h1 class="page-intro-title">{title}</h1>
            <p class="page-intro-copy">{description}</p>
          </div>

          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
